<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Parcial1LucaDepetris.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Parcial1LucaDepetris"
    xmlns:views="clr-namespace:Parcial1LucaDepetris.Views"
    Title="Parcial1LucaDepetris">

    <TabBar>
        <ShellContent
            Title="Posts"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Favoritos"
            ContentTemplate="{DataTemplate views:FavoritesPage}"
            Route="FavoritesPage" />

        <ShellContent
            Title="Sensores"
            ContentTemplate="{DataTemplate views:SensorPage}"
            Route="SensorPage" />
    </TabBar>

</Shell>
