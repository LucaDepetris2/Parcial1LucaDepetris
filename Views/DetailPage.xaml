<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Parcial1LucaDepetris.ViewModels"
             x:DataType="vm:DetailViewModel"
             x:Class="Parcial1LucaDepetris.Views.DetailPage"
             Title="Detalle del Post">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="20">

            <Label Text="ID del Post"
                   FontAttributes="Bold"
                   FontSize="12"
                   TextColor="Gray" />
            <Label Text="{Binding Post.Id}"
                   FontSize="18" />

            <Label Text="Título"
                   FontAttributes="Bold"
                   FontSize="12"
                   TextColor="Gray" />
            <Label Text="{Binding Post.Title}"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label Text="Autor (UserId)"
                   FontAttributes="Bold"
                   FontSize="12"
                   TextColor="Gray" />
            <Label Text="{Binding Post.UserId}"
                   FontSize="16" />

            <Label Text="Contenido"
                   FontAttributes="Bold"
                   FontSize="12"
                   TextColor="Gray" />
            <Label Text="{Binding Post.Body}"
                   FontSize="15"
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
