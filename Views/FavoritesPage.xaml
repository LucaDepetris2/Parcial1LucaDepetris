<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Parcial1LucaDepetris.ViewModels"
             xmlns:models="clr-namespace:Parcial1LucaDepetris.Models"
             x:DataType="vm:FavoritesViewModel"
             x:Class="Parcial1LucaDepetris.Views.FavoritesPage"
             Title="Favoritos">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <Label Grid.Row="0"
               Text="{Binding StatusMessage}"
               HorizontalOptions="Center"
               FontSize="13"
               TextColor="Gray" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Favorites}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FavoritePost">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Eliminar"
                                           BackgroundColor="Red"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=DeleteFavoriteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="0,8">
                            <Frame Padding="12" CornerRadius="8" HasShadow="True">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Body}"
                                           FontSize="12"
                                           TextColor="Gray"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
