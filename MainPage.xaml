<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Parcial1LucaDepetris.ViewModels"
             xmlns:models="clr-namespace:Parcial1LucaDepetris.Models"
             x:DataType="vm:MainViewModel"
             x:Class="Parcial1LucaDepetris.MainPage"
             Title="Posts">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Botón para cargar datos -->
        <Button Grid.Row="0"
                Text="Cargar Posts"
                Command="{Binding LoadPostsCommand}"
                IsEnabled="{Binding IsNotLoading}"
                HorizontalOptions="Fill" />

        <!-- Label de estado -->
        <Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               HorizontalOptions="Center"
               FontSize="13"
               TextColor="Gray" />

        <!-- CollectionView de posts -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Posts}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Post">
                    <Grid Padding="0,8">
                        <Frame Padding="12" CornerRadius="8" HasShadow="True">
                            <Grid>
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=SelectPostCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
